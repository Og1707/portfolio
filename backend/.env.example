# ─────────────────────────────────────
# CONFIGURACIÓN GENERAL
# ─────────────────────────────────────
APP_NAME="Osman Pérez Portfolio API"
APP_ENV=development          # development | production
DEBUG=true

# ─────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────
# Desarrollo (SQLite — sin instalar nada)
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# Producción (Railway PostgreSQL — descomenta en prod)
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

# ─────────────────────────────────────
# CORS — dominios permitidos
# ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://osmanperez.dev

# ─────────────────────────────────────
# EMAIL (para recibir mensajes del formulario)
# ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password     # Contraseña de aplicación (Gmail)
EMAIL_TO=tu_correo@gmail.com        # Donde recibes los mensajes

# ─────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────
RATE_LIMIT_CONTACT=5/minute      # Máx 5 mensajes por minuto por IP
